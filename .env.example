# Copy this to Railway's environment variables dashboard

# Trading mode - start with PAPER, change to LIVE when ready
TRADING_MODE=PAPER

# Polymarket wallet (needed for live trading only)
POLY_PRIVATE_KEY=your_private_key_here
POLY_PROXY_ADDRESS=your_proxy_address_here

# Notifications (optional)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Bot settings
MIN_EDGE=0.05
MAX_ORDER_USD=10.0
KELLY_FRACTION=0.25
SCAN_INTERVAL_SECONDS=300
